# ─── Allowlist: solo estos directorios/archivos se trackean ───
/*
!/comunidad_zapotal_backend/
!/comunidad_zapotal_frontend/
!/generate_secret_key.bat

# ─── Patrones generales dentro de las carpetas permitidas ───

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Node / React
node_modules/
dist/
build/

# Entorno y secretos
.env

# Django
staticfiles/

# Bases de datos
*.db
*.sqlite
*.sqlite3

# Logs
*.log

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
