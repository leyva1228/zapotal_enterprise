node_modules/
dist/
build/

# Entorno y secretos
.env

# Django
staticfiles/

# Bases de datos
*.db
*.sqlite
*.sqlite3

# Logs
*.log

# IDEs
.idea/
.vscode/
*.swp
*.swo

