# ─── Allowlist: solo estos directorios/archivos se trackean ───
/*
!/comunidad_zapotal_backend/
!/comunidad_zapotal_frontend/
!/generate_secret_key.bat
!/init_db.bat
!/install_backend.bat
!/install_frontend.bat
!/setup_backend.bat
!/credenciales-seed.txt
!/setup_backend.bat
!/setup.bat
!/VERSION
!/.gitignore

