{
  "info": {
    "name": "Comunidad Zapotal API",
    "description": "Colección Postman para la API REST de Comunidad Zapotal. JWT con rotación. Roles: ADMIN, COMUNERO, USUARIO.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@zapotal.pe\",\n  \"password\": \"tu_password\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/login/"}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', data.access);",
                  "  pm.collectionVariables.set('refresh_token', data.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/token/refresh/"}
          }
        },
        {
          "name": "Logout (Blacklist refresh)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/token/blacklist/"}
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@zapotal.pe\",\n  \"password\": \"mypass1234\",\n  \"tipo_usuario\": \"USUARIO\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/register/"}
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Listar usuarios (ADMIN)",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/usuarios/"}
          }
        },
        {
          "name": "Detalle usuario",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/usuarios/1/"}
          }
        },
        {
          "name": "Crear usuario (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@zapotal.pe\",\n  \"password\": \"mypass1234\",\n  \"tipo_usuario\": \"COMUNERO\",\n  \"estado\": \"ACTIVO\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/usuarios/"}
          }
        }
      ]
    },
    {
      "name": "Noticias",
      "item": [
        {
          "name": "Listar noticias",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/noticias/?ordering=-fecha_publicacion",
              "query": [{"key": "ordering", "value": "-fecha_publicacion"}]
            }
          }
        },
        {
          "name": "Detalle noticia",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/noticias/1/"}
          }
        },
        {
          "name": "Noticias relacionadas",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/noticias/1/relacionadas/"}
          }
        },
        {
          "name": "Comentarios de noticia",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/noticias/1/comentarios/"}
          }
        },
        {
          "name": "Crear noticia (ADMIN/COMUNERO)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Nueva noticia\",\n  \"contenido\": \"Contenido completo...\",\n  \"resumen\": \"Resumen breve\",\n  \"estado\": \"PUBLICADA\",\n  \"categoria\": 1\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/noticias/"}
          }
        }
      ]
    },
    {
      "name": "Comentarios",
      "item": [
        {
          "name": "Listar comentarios (filtrado por estado)",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/comentarios/?noticia=1"}
          }
        },
        {
          "name": "Crear comentario (autenticado)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noticia\": 1,\n  \"contenido\": \"Excelente artículo\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/comentarios/"}
          }
        }
      ]
    },
    {
      "name": "Reacciones",
      "item": [
        {
          "name": "Crear/toggle reacción",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noticia\": 1,\n  \"tipo\": \"LIKE\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/reacciones/"}
          }
        }
      ]
    },
    {
      "name": "Eventos",
      "item": [
        {
          "name": "Listar eventos",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/eventos/"}
          }
        },
        {
          "name": "Crear evento (ADMIN/COMUNERO)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Asamblea comunal\",\n  \"descripcion\": \"Detalles...\",\n  \"fecha\": \"2026-12-15T18:00:00Z\",\n  \"lugar\": \"Plaza principal\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/eventos/"}
          }
        }
      ]
    },
    {
      "name": "Autoridades",
      "item": [
        {
          "name": "Listar autoridades",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/autoridades/"}
          }
        }
      ]
    },
    {
      "name": "Mensajería",
      "item": [
        {
          "name": "Listar mis mensajes",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/mensajes/"}
          }
        },
        {
          "name": "Enviar mensaje",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destinatario\": 2,\n  \"contenido\": \"Hola, ¿cómo estás?\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/mensajes/"}
          }
        },
        {
          "name": "Listar mis notificaciones",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/v1/notificaciones/"}
          }
        }
      ]
    },
    {
      "name": "Reclamaciones y Contacto",
      "item": [
        {
          "name": "Enviar mensaje de contacto (público)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Visitante\",\n  \"email\": \"visitante@example.com\",\n  \"asunto\": \"Consulta general\",\n  \"mensaje\": \"Quisiera más información...\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/contacto-mensajes/"}
          }
        },
        {
          "name": "Libro de Reclamaciones (público)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Consumidor\",\n  \"email\": \"consumidor@example.com\",\n  \"telefono\": \"987654321\",\n  \"direccion\": \"Av. Test 123\",\n  \"tipo\": \"QUEJA\",\n  \"descripcion\": \"Detalle de la queja con suficiente detalle\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/libro-reclamaciones/"}
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/health/"}
          }
        },
        {
          "name": "Liveness probe",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/health/live/"}
          }
        },
        {
          "name": "Readiness probe",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/health/ready/"}
          }
        }
      ]
    }
  ]
}
