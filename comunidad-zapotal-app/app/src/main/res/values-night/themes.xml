<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema Base -->
    <style name="Base.Theme.ComunidadZapotal"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- COLOR PRINCIPAL -->
        <item name="colorPrimary">@color/emerald_main</item>
        <item name="colorSecondary">@color/emerald_dark</item>
        <item name="colorTertiary">@color/emerald_light</item>

        <!-- STATUS BAR -->
        <item name="android:statusBarColor">@color/emerald_dark</item>

        <!-- NAVIGATION BAR -->
        <item name="android:navigationBarColor">@color/emerald_main</item>

        <!-- ICONOS BLANCOS -->
        <item name="android:windowLightStatusBar">false</item>

    </style>

    <!-- Tema principal -->
    <style name="Theme.ComunidadZapotal"
        parent="Base.Theme.ComunidadZapotal" />

    <!-- Imagen circular -->
    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Bordes redondeados -->
    <style name="Rounded12" parent="">
        <item name="cornerSize">12dp</item>
    </style>

</resources>