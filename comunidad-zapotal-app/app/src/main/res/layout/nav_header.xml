<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@drawable/bg_header_home"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgNavHeader"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_logo_background"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="#10B981"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/txtNombreNavHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Juyin Garcia"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtRolNavHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Miembro de Comunidad Zapotal"
        android:textColor="#10B981"
        android:textSize="14sp" />

</LinearLayout>