<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <!-- HEADER: TITULO Y ORDENAR -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eventos"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnSortEventos"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_sort"
                app:tint="#10B981" />
        </RelativeLayout>

        <!-- BUSCADOR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="14dp"
            app:strokeColor="#22FFFFFF"
            app:strokeWidth="1dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchViewEventos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:iconifiedByDefault="false"
                app:queryBackground="@android:color/transparent"
                app:queryHint="Buscar eventos..."
                app:searchIcon="@drawable/ic_event" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TABS: PROXIMOS / PASADOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/tabProximos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:text="Próximos"
                android:textColor="#10B981"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabPasados"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:text="Pasados"
                android:textColor="#9CA3AF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:id="@+id/tabIndicator"
            android:layout_width="180dp"
            android:layout_height="2dp"
            android:background="#10B981"
            android:layout_marginStart="16dp" />

        <!-- RECYCLERVIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTodosEventos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/layoutEmptyEventos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="100dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_event"
            app:tint="#4B5563"
            android:alpha="0.5" />

        <TextView
            android:id="@+id/txtEmptyMessageEventos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No hay eventos próximamente"
            android:textColor="#9CA3AF"
            android:textSize="16sp" />
    </LinearLayout>

</FrameLayout>