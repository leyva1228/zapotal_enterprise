<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#111111"
    app:cardCornerRadius="16dp"
    app:strokeColor="#1AFFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- IMAGEN IZQUIERDA -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgEvento"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/Rounded12"
            tools:src="@drawable/ic_launcher_background" />

        <!-- CONTENIDO DERECHA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTituloEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Fiesta Patronal" />

            <TextView
                android:id="@+id/txtDescripcionCorta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                tools:text="Celebración anual en la plaza..." />

            <!-- PILL DE FECHA -->
            <LinearLayout
                android:id="@+id/containerFechaPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_pill_action"
                android:backgroundTint="#064E3B"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_event"
                    app:tint="#10B981" />

                <TextView
                    android:id="@+id/txtFechaEvento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="#10B981"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="20 de mayo, 2026" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtPublicadoEl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#6B7280"
                android:textSize="11sp"
                tools:text="Publicado el 18 de mayo 2026" />

        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_arrow_right"
            app:tint="#4B5563" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>