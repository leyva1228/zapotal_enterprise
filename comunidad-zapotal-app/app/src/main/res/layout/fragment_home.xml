<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/emerald_dark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/imgLogoApp"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@mipmap/ic_logo_foreground"
                android:scaleType="fitCenter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@id/imgLogoApp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/imgLogoApp"
                app:layout_constraintBottom_toBottomOf="@id/imgLogoApp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¡Hola!"
                    android:textColor="@color/emerald_soft"
                    android:textSize="14sp"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comunidad Zapotal"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:layout_marginTop="-4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unidos por el desarrollo"
                    android:textColor="@color/teal_light"
                    android:textSize="12sp"
                    android:alpha="0.6" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- CARRUSEL DESTACADOS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destacados"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPagerDestacados"
            android:layout_width="match_parent"
            android:layout_height="310dp"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:id="@+id/layoutIndicadores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="8dp" />

        <!-- NOTICIAS RECIENTES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Noticias recientes"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerNoticias"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginTop="12dp" />

        <!-- EVENTOS RECIENTES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eventos recientes"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEventos"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginTop="12dp" />

        <!-- SECCIÓN SOBRE LA COMUNIDAD -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre la comunidad"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_dark"
            app:cardCornerRadius="24dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/white_10">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp">

                    <!-- Logo -->
                    <ImageView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_gravity="center"
                        android:src="@mipmap/ic_logo_foreground"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <!-- Título -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="-12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comunidad "
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="24sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zapotal"
                        android:textColor="@color/emerald_main"
                        android:textStyle="bold"
                        android:textSize="24sp" />
                </LinearLayout>

                <!-- Línea verde decorativa -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="@color/emerald_main"
                    android:layout_marginTop="6dp" />

                <!-- Descripción -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="La Comunidad Zapotal promueve la unión, el desarrollo y el bienestar de todos sus integrantes a través de la colaboración activa."
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="28dp"
                    android:paddingHorizontal="32dp"
                    android:lineSpacingExtra="5dp"
                    android:alpha="0.9" />

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white_10" />

                <!-- Valores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="24dp"
                    android:baselineAligned="false">

                    <!-- Union -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_group"
                            app:tint="@color/emerald_main" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unión"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Juntos somos\nmás fuertes."
                            android:textColor="@color/gray_text"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="45dp"
                        android:background="@color/white_10"
                        android:layout_gravity="center_vertical" />

                    <!-- Desarrollo -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_leaf"
                            app:tint="@color/emerald_main" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Desarrollo"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Impulsamos el\nprogreso."
                            android:textColor="@color/gray_text"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="45dp"
                        android:background="@color/white_10"
                        android:layout_gravity="center_vertical" />

                    <!-- Bienestar -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_heart"
                            app:tint="@color/emerald_main" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bienestar"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trabajamos por una\nmejor calidad de vida."
                            android:textColor="@color/gray_text"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white_10" />

                <!-- Ubicación Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerUbicacion"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/ver_en_google_maps"
                    android:textColor="@color/emerald_main"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_arrow_right"
                    app:iconGravity="textEnd"
                    app:iconTint="@color/emerald_main" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AUTORIDADES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autoridades"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAutoridades"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="30dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
